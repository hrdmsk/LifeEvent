# ローカル開発用のシークレット。コピーして .dev.vars を作り、実際の値を入れる。
# .dev.vars は .gitignore 済み（コミットされない）。本番は `wrangler secret put <NAME>`。

# Better Auth
BETTER_AUTH_URL="http://localhost:5173"
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"

# World ID（World ID Developer Portal のアプリから取得）
WORLDID_APP_ID="app_xxxxxxxxxxxxxxxx"
WORLDID_CLIENT_SECRET="your-world-id-client-secret"
