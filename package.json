{
  "name": "lifeevent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply lifeevent --local",
    "migrate:remote": "wrangler d1 migrations apply lifeevent --remote"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "hono": "^4.6.14",
    "kysely": "^0.29.3",
    "kysely-d1": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^12.11.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^3.99.0"
  }
}
